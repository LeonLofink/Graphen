+        super(x,y,text,textsize,true);
+        buttonHandler = bH;
+        buttonHandler.getViewController().draw(this,buttonHandler.getSceneIndex());
+        buttonHandler.getViewController().register(this,buttonHandler.getSceneIndex());
+        this.actionCode = actionCode;
