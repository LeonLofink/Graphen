+        drawTool.drawCircle(x,y,r);
+        drawTool.drawCircle(x+r,y+r*0.75,r);
+        drawTool.drawCircle(x+r*0.5,y-r*0.5,r);
+        drawTool.drawCircle(x+r*2,y+r*0.25,r);
