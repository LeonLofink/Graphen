+    public void drawFilledCircle(double x, double y, double radius){
+        Ellipse2D.Double e = new Ellipse2D.Double(x-radius,y-radius,radius*2,radius*2);
+        if (graphics2D!= null) graphics2D.fill(e);
+    }
